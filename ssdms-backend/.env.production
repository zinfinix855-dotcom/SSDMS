PORT=5000
NODE_ENV=production

# Production configuration placeholders. DO NOT store real secrets in the repo.
DB_HOST=db
DB_USER=root
DB_PASSWORD=change_this_in_deployment
DB_NAME=ssdms
DB_PORT=3306

REDIS_HOST=redis
REDIS_PORT=6379

# JWT (set via deployment secret management)
JWT_SECRET=replace_with_secret_from_vault
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace_with_refresh_secret_from_vault
JWT_REFRESH_EXPIRES_IN=7d

# Sentry DSN should be injected at deploy time
SENTRY_DSN=
